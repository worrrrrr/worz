# WORZ SOVEREIGN CORE Environment Variables
# Symbolic-only Mode (No LLM Required)

# System Mode: symbolic_only, hybrid, llm_only
LLM_MODE=symbolic_only

# Optional: Groq API Key (for hybrid/llm mode only)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Ollama Configuration (for local LLM mode)
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://localhost:11434

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
